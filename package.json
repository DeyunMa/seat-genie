{
  "name": "seat-genie-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=seat-genie-frontend\" \"npm run dev --workspace=seat-genie-backend\"",
    "install:all": "npm install",
    "build:frontend": "npm run build --workspace=seat-genie-frontend",
    "test:backend": "npm test --workspace=seat-genie-backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
